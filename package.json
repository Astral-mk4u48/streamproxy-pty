{
  "name": "streamproxy-pty",
  "displayName": "StreamProxy PTY",
  "description": "Intercepts terminal stdout, extracts JSON payloads, and renders them in a virtualized side panel.",
  "version": "0.1.4",
  "publisher": "astral-mk4u48",
  "repository": {
    "type": "git",
    "url": "https://github.com/Astral-mk4u48/streamproxy-pty.git"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "streamproxy-container",
          "title": "StreamProxy",
          "icon": "resources/icon-activitybar.svg"
        }
      ]
    },
    "views": {
      "streamproxy-container": [
        {
          "type": "webview",
          "id": "streamproxy-pty.jsonView",
          "name": "JSON Payloads"
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "title": "StreamProxy Shell",
          "id": "streamproxy-pty.profile",
          "icon": "terminal"
        }
      ]
    },
    "commands": [
      {
        "command": "streamproxy-pty.openPanel",
        "title": "StreamProxy: Open JSON Panel",
        "icon": "$(json)"
      },
      {
        "command": "streamproxy-pty.clearPanel",
        "title": "StreamProxy: Clear JSON Panel"
      }
    ],
    "configuration": {
      "title": "StreamProxy PTY",
      "properties": {
        "streamproxy-pty.placeholderStyle": {
          "type": "string",
          "enum": ["inline", "minimal"],
          "default": "inline",
          "description": "How JSON placeholders appear in the terminal."
        },
        "streamproxy-pty.maxPanelEntries": {
          "type": "number",
          "default": 500,
          "description": "Maximum number of JSON payloads kept in the panel before oldest are pruned."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build-webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-webview": "cd webview && npm install && npm run build",
    "watch-webview": "cd webview && npm run watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  }
}